{
  "name": "get_orderbook",
  "description": "Get current orderbook snapshot (bids/asks). Used for ILD, ROL, OGM metrics.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "symbol": { "type": "string" },
      "limit": { "type": "integer", "default": 50 },
      "category": { "type": "string", "default": "spot" }
    },
    "required": ["symbol"]
  }
}