# Bybit API Configuration
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_ENV=demo  # demo | live

# Trading Settings
SYMBOL=BTCUSDT
TIMEFRAME=1m
ORDER_TYPE=limit
TIME_IN_FORCE=GoodTillCancel
ORDERBOOK_DEPTH=5

# Risk Management
CAPITAL_USDT=5000.0
FEE_RATE=0.002
RISK_FACTOR=0.01
TP_PERCENTAGE=0.02
SL_PERCENTAGE=0.01
MIN_TRADE_SIZE=0.001
MAX_TRADE_SIZE=0.01
MAX_ITERATIONS=1000

# Qwen Cloud (DashScope) AI Configuration
# Get your key: https://dashscope.console.aliyun.com/
# Hackathon credits: https://www.qwencloud.com/challenge/hackathon/voucher-application
DASHSCOPE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8081
NERTZH_API=http://localhost:8081
MONITOR_PORT=8090

# Strategy Parameters
EGM_BUY_THRESHOLD=0.5
EGM_SELL_THRESHOLD=-0.5
COMBINED_BUY_THRESHOLD=1.0
COMBINED_SELL_THRESHOLD=-1.0
PIO_THRESHOLD=0.1
DEFAULT_SLEEP_TIME=60

# ── Cálculo de cantidad ──
BASE_VOLATILITY=0.01
MIN_VOLATILITY_FLOOR=0.001
MAX_POSITION_PCT=0.10

# ── Métricas ──
# METRIC_WEIGHTS='{"egm": 0.20, "ild": 0.30, "rol": 0.30, "pio": 0.10, "ogm": 0.10}'
COMBINED_SCALE=10.0
COMBINED_CLAMP=10.0
MIN_PRICE_RANGE_PCT=0.01
SPREAD_REFERENCE=0.02
EPSILON=0.00000001

# ── Throttling ──
KLINE_STALE_MS=60000
TICKER_TRADE_COOLDOWN_S=30
ORDERBOOK_LOG_INTERVAL_S=5
BALANCE_SYNC_INTERVAL_S=60

# ── Reintentos ──
ORDER_MAX_RETRIES=3
ORDER_MAX_BACKOFF_S=8
ORDER_RETRY_BASE_DELAY_S=2

# ── Red ──
WS_RECONNECT_DELAY_S=5
WS_MAX_RECONNECT_ATTEMPTS=10
HTTP_TIMEOUT_S=10

# ── TSM Exchange Formulas (real metrics from QuestDB + Postgres) ──
TSM_ENABLED=true
TSM_TIMEOUT_S=8
TSM_FORMULAS_PATH=D:\documentos\trae_projects\Tsm_exanges_formulas
TSM_DATA_SOURCE=postgres,questdb,sqlite
TSM_QUESTDB_TRADES=true

# QuestDB (market trades, BBO) — HTTP :9000, ILP :9009
QUESTDB_HOST=localhost
QUESTDB_HTTP_PORT=9000

# PostgreSQL (full L2 orderbook) — port 5433 in TSM stack
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=trading
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# TSM combined weights (validated pipeline params)
TSM_W_ILD=0.30
TSM_W_EGM=0.20
TSM_W_ROL=0.30
TSM_W_PIO=0.10
TSM_ROL_SCALE=2.8
TSM_OGM_SCALE=1.15