# Bybit API Configuration
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_ENV=demo  # Can be either 'demo' or 'live'

# Trading Settings
SYMBOL=BTCUSDT
TIMEFRAME=1m
ORDER_TYPE=limit
TIME_IN_FORCE=GoodTillCancel
ORDERBOOK_DEPTH=5

# Risk Management
CAPITAL_USDT=5000.0
FEE_RATE=0.002
RISK_FACTOR=0.01
TP_PERCENTAGE=0.02
SL_PERCENTAGE=0.01
MIN_TRADE_SIZE=0.001
MAX_TRADE_SIZE=100.0
MAX_ITERATIONS=1000

# Strategy Parameters
EGM_BUY_THRESHOLD=0.5
EGM_SELL_THRESHOLD=-0.5
PIO_THRESHOLD=0.1
DEFAULT_SLEEP_TIME=60
